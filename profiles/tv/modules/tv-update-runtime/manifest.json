{
  "schema": "harmonia.module.ladder.v1",
  "id": "tv-update-runtime",
  "version": "1.0.0",
  "description": "TV rolling-release convergence scheduler ladder: managed unit files, daemon reload, timer enable-now.",
  "constants": {},
  "ladder": [
    {"step_id": "tv-update-managed-files", "tool": "files", "permutation": "managed-files", "args": {}},
    {"step_id": "tv-update-daemon-reload", "tool": "systemd", "permutation": "daemon-reload", "args": {"timeout_secs": 30}},
    {"step_id": "tv-update-timer-enable", "tool": "systemd", "permutation": "enable-now", "args": {"service": "harmonia-tv.timer", "timeout_secs": 30}}
  ],
  "files_root": "files_root"
}