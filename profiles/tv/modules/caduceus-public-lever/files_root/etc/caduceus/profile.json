{
  "schema": "caduceus.profile.v1",
  "profile": "tv",
  "mode": "tv",
  "harmonia_profile": "/etc/harmonia/profiles/tv/index.json",
  "commands": [
    "help",
    "identity show",
    "profile show",
    "health",
    "receipts latest",
    "update status",
    "update check",
    "update now",
    "update service status",
    "update service toggle",
    "cert status",
    "cert issue-leaf",
    "cert rotate-ca",
    "cert bundle create"
  ],
  "services": {
    "update": {
      "timer": "harmonia.timer",
      "latest_receipt": "/var/lib/harmonia/receipts/tv-latest/run.json"
    }
  },
  "harmonia_routes": {
    "update_now": {
      "bin": "/usr/local/bin/harmonia",
      "args": [
        "run-profile",
        "/etc/harmonia/profiles/tv/index.json",
        "--apply",
        "--receipt-dir",
        "/var/lib/harmonia/receipts/tv-latest"
      ]
    },
    "update_check": {
      "bin": "/usr/local/bin/harmonia",
      "args": [
        "run-profile",
        "/etc/harmonia/profiles/tv/index.json",
        "--receipt-dir",
        "/var/lib/harmonia/receipts/tv-check-latest"
      ]
    }
  }
}
