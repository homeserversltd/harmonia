          "-c",
          "command -v waybar >/dev/null"
        ],
        "timeout_secs": 30
      }
    },
    {
      "step_id": "binary-dunst",
      "tool": "command",
      "permutation": "capture",
      "args": {
        "program": "/usr/bin/env",
        "args": [
          "sh",
          "-c",
          "command -v dunst >/dev/null"
        ],
        "timeout_secs": 30
      }
    },
    {
      "step_id": "binary-chromium",
      "tool": "command",
      "permutation": "capture",
      "args": {
        "program": "/usr/bin/env",
        "args": [
          "sh",
          "-c",
          "command -v chromium >/dev/null"
        ],
        "timeout_secs": 30
      }
    },
    {
