{
  "schema": "harmonia.module.ladder.v1",
  "id": "homeconsole-update-runtime",
  "version": "3.6.0",
  "description": "HomeConsole convergence scheduler ladder: managed unit files, daemon reload, timer enable-now.",
  "constants": {},
  "ladder": [
    {
      "step_id": "homeconsole-update-managed-files",
      "tool": "files",
      "permutation": "managed-files",
      "args": {}
    },
    {
      "step_id": "homeconsole-update-daemon-reload",
      "tool": "systemd",
      "permutation": "daemon-reload",
      "args": {
        "timeout_secs": 30
      }
    },
    {
      "step_id": "homeconsole-update-timer-enable",
      "tool": "systemd",
      "permutation": "enable-now",
      "args": {
        "service": "harmonia-homeconsole.timer",
        "timeout_secs": 30
      }
    }
  ],
  "files_root": "files_root"
}
