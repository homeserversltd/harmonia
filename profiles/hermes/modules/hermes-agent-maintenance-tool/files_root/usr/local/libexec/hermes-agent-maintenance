#!/usr/bin/env python3
"""Update one Hermes Agent installation and restart only its selected gateway."""

from __future__ import annotations

import fcntl
import json
import os
import re
import subprocess
import sys
import tempfile
import time
from datetime import datetime, timezone
from pathlib import Path
from typing import Any

SCHEMA = "harmonia.hermes-agent-maintenance.receipt.v1"
PROFILE_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*$")


def env_path(name: str, default: str) -> Path:
    return Path(os.environ.get(name, default)).expanduser()


def command_result(argv: list[str], timeout: int) -> dict[str, Any]:
    try:
        result = subprocess.run(argv, text=True, capture_output=True, timeout=timeout, check=False)
        return {
            "argv": argv,
            "ok": result.returncode == 0,
            "exit_code": result.returncode,
            "stdout": result.stdout[-12000:],
            "stderr": result.stderr[-12000:],
        }
    except subprocess.TimeoutExpired as exc:
        return {
            "argv": argv,
            "ok": False,
            "exit_code": -1,
            "stdout": (exc.stdout or "")[-12000:] if isinstance(exc.stdout, str) else "",
            "stderr": "command timed out",
        }
    except OSError as exc:
        return {
            "argv": argv,
            "ok": False,
            "exit_code": -1,
            "stdout": "",
            "stderr": str(exc),
        }


def retry_command(argv: list[str], timeout: int, attempts: int = 10) -> dict[str, Any]:
    result: dict[str, Any] = {}
    for attempt in range(1, attempts + 1):
        result = command_result(argv, timeout)
        result["attempts"] = attempt
        if result["ok"]:
            return result
        if attempt < attempts:
            time.sleep(1)
    return result


def atomic_json(path: Path, payload: dict[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd, temporary = tempfile.mkstemp(prefix=f".{path.name}.", dir=path.parent)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as handle:
            json.dump(payload, handle, indent=2, sort_keys=True)
            handle.write("\n")
            handle.flush()
            os.fsync(handle.fileno())
        os.replace(temporary, path)
    finally:
        try:
            os.unlink(temporary)
        except FileNotFoundError:
            pass


def profile_prefix(hermes_bin: str, profile: str) -> list[str]:
    if profile in ("", "default"):
        return [hermes_bin]
    return [hermes_bin, "-p", profile]


def gateway_contract(hermes_bin: str, profile: str) -> tuple[str | None, list[str], str]:
    mode = os.environ.get("HERMES_MAINTENANCE_GATEWAY_MODE", "dedicated").strip()
    if mode == "dedicated":
        expected = (
            "hermes-gateway.service"
            if profile == "default"
            else f"hermes-gateway-{profile}.service"
        )
        status_prefix = profile_prefix(hermes_bin, profile)
    elif mode == "multiplex-default":
        expected = "hermes-gateway.service"
        status_prefix = [hermes_bin]
    elif mode == "none":
        declared = os.environ.get("HERMES_MAINTENANCE_GATEWAY_UNIT", "").strip()
        if declared:
            raise ValueError("hermes-gateway-unit-forbidden")
        return None, [], mode
    else:
        raise ValueError("hermes-gateway-mode-invalid")

    declared = os.environ.get("HERMES_MAINTENANCE_GATEWAY_UNIT", "").strip()
    if declared and declared != expected:
        raise ValueError("hermes-gateway-unit-mismatch")
    return expected, status_prefix, mode


def gateway_status_healthy(result: dict[str, Any]) -> bool:
    if not result["ok"]:
        return False
    text = f"{result['stdout']}\n{result['stderr']}".lower()
    if any(marker in text for marker in ("not running", "inactive", "stopped", "failed")):
        return False
    return any(marker in text for marker in ("running", "active"))


def finish(receipt_path: Path, receipt: dict[str, Any], ok: bool, state: str) -> int:
    receipt.update({
        "completed_at": datetime.now(timezone.utc).isoformat(),
        "ok": ok,
        "state": state,
        "first_missing_signal": "none" if ok else state,
    })
    try:
        atomic_json(receipt_path, receipt)
    except OSError as exc:
        receipt.update({
            "ok": False,
            "state": "hermes-receipt-write-failed",
            "first_missing_signal": "hermes-receipt-write-failed",
            "receipt_error": str(exc),
        })
        print(json.dumps(receipt, sort_keys=True), file=sys.stderr)
        return 1
    return 0 if ok else 1


def main() -> int:
    profile = os.environ.get("HERMES_MAINTENANCE_PROFILE", "default").strip() or "default"
    receipt_dir = env_path(
        "HERMES_MAINTENANCE_RECEIPT_DIR",
        "~/.local/state/harmonia/hermes-agent-maintenance",
    )
    receipt_path = receipt_dir / "latest.json"
    receipt: dict[str, Any] = {
        "schema": SCHEMA,
        "started_at": datetime.now(timezone.utc).isoformat(),
        "profile": profile,
        "backup_mode": os.environ.get("HERMES_MAINTENANCE_BACKUP_MODE", "default"),
        "commands": {},
    }

    if not PROFILE_RE.fullmatch(profile):
        receipt["changed"] = False
        return finish(receipt_path, receipt, False, "hermes-profile-invalid")

    hermes_bin = os.environ.get("HERMES_MAINTENANCE_HERMES_BIN", "hermes")
    systemctl_bin = os.environ.get("HERMES_MAINTENANCE_SYSTEMCTL_BIN", "systemctl")
    try:
        timeout = int(os.environ.get("HERMES_MAINTENANCE_TIMEOUT_SECONDS", "1800"))
        if timeout <= 0:
            raise ValueError
    except ValueError:
        receipt["changed"] = False
        return finish(receipt_path, receipt, False, "hermes-timeout-invalid")

    try:
        unit, status_prefix, gateway_mode = gateway_contract(hermes_bin, profile)
    except ValueError as exc:
        receipt["changed"] = False
        return finish(receipt_path, receipt, False, str(exc))
    receipt["gateway_unit"] = unit
    receipt["gateway_mode"] = gateway_mode
    if gateway_mode == "none":
        receipt["gateway_restart_attempted"] = False

    runtime = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp"))
    lock_path = env_path(
        "HERMES_MAINTENANCE_LOCK_PATH",
        str(runtime / f"hermes-agent-maintenance-{profile}.lock"),
    )
    try:
        lock_path.parent.mkdir(parents=True, exist_ok=True)
        lock_handle = lock_path.open("a+", encoding="utf-8")
    except OSError as exc:
        receipt["changed"] = False
        receipt["lock_error"] = str(exc)
        return finish(receipt_path, receipt, False, "hermes-lock-open-failed")

    with lock_handle as lock:
        try:
            fcntl.flock(lock.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            receipt["changed"] = False
            return finish(
                receipt_dir / "last-skipped-locked.json",
                receipt,
                True,
                "skipped-locked",
            )

        prefix = profile_prefix(hermes_bin, profile)
        version_before = command_result([hermes_bin, "--version"], 30)
        receipt["commands"]["version_before"] = version_before
        if not version_before["ok"]:
            receipt["changed"] = False
            receipt["gateway_restart_attempted"] = False
            return finish(receipt_path, receipt, False, "hermes-pre-update-cli-failed")

        check = command_result(prefix + ["update", "--check"], min(timeout, 300))
        receipt["commands"]["update_check"] = check
        if not check["ok"]:
            receipt["changed"] = False
            return finish(receipt_path, receipt, False, "hermes-update-check-failed")

        check_text = f"{check['stdout']}\n{check['stderr']}".lower()
        update_available = (
            "update available" in check_text and "no update available" not in check_text
        )
        already_current = any(
            marker in check_text
            for marker in ("up to date", "up-to-date", "already current", "no update available")
        )
        if not update_available and not already_current:
            receipt["changed"] = False
            return finish(receipt_path, receipt, False, "hermes-update-check-ambiguous")

        if update_available:
            update_argv = prefix + ["update", "--yes"]
            backup_mode = receipt["backup_mode"]
            if backup_mode == "force":
                update_argv.append("--backup")
            elif backup_mode == "skip":
                update_argv.append("--no-backup")
            elif backup_mode != "default":
                receipt["changed"] = False
                return finish(receipt_path, receipt, False, "hermes-backup-mode-invalid")
            update = command_result(update_argv, timeout)
            receipt["commands"]["update"] = update
            if not update["ok"]:
                receipt["changed"] = False
                receipt["gateway_restart_attempted"] = False
                return finish(receipt_path, receipt, False, "hermes-update-failed")

        version_after = command_result([hermes_bin, "--version"], 30)
        receipt["commands"]["version_after"] = version_after
        if not version_after["ok"]:
            receipt["changed"] = update_available
            receipt["gateway_restart_attempted"] = False
            return finish(receipt_path, receipt, False, "hermes-post-update-cli-failed")

        if gateway_mode == "none":
            receipt["update_available"] = update_available
            receipt["updated"] = update_available
            receipt["changed"] = update_available
            return finish(
                receipt_path,
                receipt,
                True,
                "updated-no-gateway" if update_available else "current-no-gateway",
            )

        unit = receipt["gateway_unit"]
        assert isinstance(unit, str)
        restart = command_result([systemctl_bin, "--user", "restart", unit], 120)
        receipt["commands"]["gateway_restart"] = restart
        receipt["gateway_restart_attempted"] = True
        if not restart["ok"]:
            receipt["changed"] = update_available
            return finish(receipt_path, receipt, False, "hermes-gateway-restart-failed")

        active = retry_command(
            [systemctl_bin, "--user", "is-active", "--quiet", unit], 30
        )
        receipt["commands"]["gateway_active"] = active
        if not active["ok"]:
            receipt["changed"] = True
            return finish(receipt_path, receipt, False, "hermes-gateway-inactive")

        gateway_status = retry_command(status_prefix + ["gateway", "status"], 60)
        receipt["commands"]["gateway_status"] = gateway_status
        if not gateway_status_healthy(gateway_status):
            receipt["changed"] = True
            return finish(receipt_path, receipt, False, "hermes-gateway-status-failed")

        receipt["update_available"] = update_available
        receipt["updated"] = update_available
        receipt["changed"] = True
        return finish(receipt_path, receipt, True, "gateway-restarted-after-update" if update_available else "gateway-restarted-current")


if __name__ == "__main__":
    raise SystemExit(main())
