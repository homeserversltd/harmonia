{
  "schema": "harmonia.module.sidecar.v1",
  "id": "systemd",
  "description": "HOMESERVER systemd units and mounts. Files live inside this module and render with safe public defaults.",
  "source_dir": "profiles/homeserver/modules/systemd/files",
  "variables": {
    "transmission_description": "Start Transmission VPN and Services",
    "nas_mount_description": "NAS Mount Status",
    "vault_mount_description": "Vault Mount Point",
    "vault_scripts_dir": "/vault/scripts",
    "vault_mount_path": "/vault",
    "vault_mapper_name": "vault"
  },
  "template_files": [
    {
      "source": "transmissionPIA.service.tmpl",
      "target": "/etc/systemd/system/transmissionPIA.service",
      "mode": 420
    },
    {
      "source": "mountNas.service.tmpl",
      "target": "/etc/systemd/system/mountNas.service",
      "mode": 420
    },
    {
      "source": "vault.mount.tmpl",
      "target": "/etc/systemd/system/vault.mount",
      "mode": 420
    }
  ],
  "deployable_consumption": {
    "authority": "harmonia-profile-module-owned-files",
    "mode": "export-rendered-module-with-receipt",
    "forbidden": "duplicate deployable-owned systemd config truth"
  },
  "module_file_locality": "systemd files live inside profiles/homeserver/modules/systemd/files"
}
