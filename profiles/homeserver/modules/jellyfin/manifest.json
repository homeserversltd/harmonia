{
  "schema": "harmonia.module.ladder.v1",
  "id": "jellyfin",
  "version": "1.0.0",
  "description": "Generic Jellyfin media service maintenance: package currentness, jellyfin.service convergence, and default localhost health proof.",
  "constants": {},
  "ladder": [
    {
      "step_id": "jellyfin-package-install",
      "tool": "package",
      "permutation": "install",
      "args": {
        "packages": [
          "jellyfin"
        ]
      }
    },
    {
      "step_id": "jellyfin-service-enable",
      "tool": "systemd",
      "permutation": "enable-now",
      "args": {
        "service": "jellyfin.service"
      }
    },
    {
      "step_id": "jellyfin-health",
      "tool": "health",
      "permutation": "probe",
      "args": {
        "url": "http://127.0.0.1:8096/health",
        "timeout_secs": 3,
        "retries": 1
      }
    }
  ]
}
