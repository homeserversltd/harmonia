{
  "schema": "harmonia.module.sidecar.v1",
  "id": "system-files",
  "description": "Reusable HOMESERVER systemd and udev file pack. Rust renders templates with variable replacement and can converge them onto installed targets.",
  "source_dir": "profiles/homeserver/modules/system-files/files",
  "variables": {
    "transmission_description": "Start Transmission VPN and Services",
    "nas_mount_description": "NAS Mount Status",
    "vault_mount_description": "Vault Mount Point",
    "vault_scripts_dir": "/vault/scripts",
    "vault_mount_path": "/vault",
    "vault_mapper_name": "vault",
    "web_runtime_group": "www-data"
  },
  "template_files": [
    {
      "source": "systemd/transmissionPIA.service.tmpl",
      "target": "/etc/systemd/system/transmissionPIA.service",
      "mode": 420
    },
    {
      "source": "systemd/mountNas.service.tmpl",
      "target": "/etc/systemd/system/mountNas.service",
      "mode": 420
    },
    {
      "source": "systemd/vault.mount.tmpl",
      "target": "/etc/systemd/system/vault.mount",
      "mode": 420
    },
    {
      "source": "udev/99-rapl-permissions.rules.tmpl",
      "target": "/etc/udev/rules.d/99-rapl-permissions.rules",
      "mode": 420
    }
  ],
  "deployable_consumption": {
    "authority": "harmonia-profile-module-owned-files",
    "mode": "export-rendered-pack-with-receipt",
    "forbidden": "duplicate deployable-owned systemd or udev config truth"
  },
  "module_file_locality": "templates and file payloads live inside this module directory"
}
