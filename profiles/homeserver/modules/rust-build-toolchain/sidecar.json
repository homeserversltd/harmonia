{
  "schema": "harmonia.module.sidecar.v1",
  "id": "rust-build-toolchain",
  "description": "HOMESERVER Rust build toolchain parity. Harmonia maintains the same current rustup/cargo toolchain surface that deployables seed at birth.",
  "packages": [
    "ca-certificates",
    "curl",
    "gcc",
    "make",
    "pkg-config"
  ],
  "expected_files": [
    "/opt/rustup",
    "/opt/cargo",
    "/usr/local/bin/rustc",
    "/usr/local/bin/cargo",
    "/usr/local/bin/rustup"
  ],
  "variables": {
    "RUSTUP_HOME": "/opt/rustup",
    "CARGO_HOME": "/opt/cargo",
    "TOOLCHAIN": "stable",
    "MINIMUM_RUSTC": "1.91.0"
  },
  "managed_files": [
    {
      "path": "/usr/local/bin/rustc",
      "mode": 493,
      "content": "#!/bin/sh\nexport RUSTUP_HOME=/opt/rustup\nexport CARGO_HOME=/opt/cargo\nexec /opt/cargo/bin/rustc \"$@\"\n"
    },
    {
      "path": "/usr/local/bin/cargo",
      "mode": 493,
      "content": "#!/bin/sh\nexport RUSTUP_HOME=/opt/rustup\nexport CARGO_HOME=/opt/cargo\nexec /opt/cargo/bin/cargo \"$@\"\n"
    },
    {
      "path": "/usr/local/bin/rustup",
      "mode": 493,
      "content": "#!/bin/sh\nexport RUSTUP_HOME=/opt/rustup\nexport CARGO_HOME=/opt/cargo\nexec /opt/cargo/bin/rustup \"$@\"\n"
    }
  ]
}
