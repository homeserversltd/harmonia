{
  "schema": "harmonia.module.ladder.v1",
  "id": "caduceus",
  "version": "1.3.1",
  "description": "HOMESERVER Caduceus public lever with a provisioned caduceus_staff Python environment and sudoers refresh consumer declaration.",
  "constants": {
    "staff_venv": "/var/lib/caduceus/venv",
    "staff_module_root": "/usr/local/sbin",
    "sudoers_refresh_consumer_role": "caduceus"
  },
  "ladder": [
    {
      "step_id": "caduceus-staff-venv",
      "tool": "command",
      "permutation": "capture",
      "args": {
        "program": "/usr/bin/python3",
        "args": [
          "-m",
          "venv",
          "/var/lib/caduceus/venv"
        ]
      }
    },
    {
      "step_id": "caduceus-service-runtime",
      "tool": "service-runtime",
      "permutation": "converge",
      "args": {
        "module_id": "caduceus",
        "repo": "https://git.home.arpa/HOMESERVERSLTD/caduceus.git",
        "branch": "main",
        "bearer": "owner",
        "source_dir": "/opt/caduceus/source",
        "install_bin": "/usr/local/bin/caduceus",
        "service": "caduceus.service",
        "url": "http://127.0.0.1:3014/health",
        "source_sha_file": "/var/lib/harmonia/state/caduceus.sha",
        "binary_name": "caduceus",
        "op_prefix": "caduceus",
        "run_schema": "harmonia.homeserver.caduceus_public_lever.v1",
        "managed_files_schema": "harmonia.homeserver.caduceus_managed_files.v1",
        "managed_files": [
          {
            "path": "/etc/caduceus/identity.json",
            "mode": 420,
            "content": "{\n  \"schema\": \"caduceus.identity.v1\",\n  \"device\": \"homeserver\",\n  \"profile\": \"homeserver\",\n  \"mode\": \"homeserver\",\n  \"public_surface\": true,\n  \"harmonia_profile\": \"/etc/harmonia/profiles/homeserver/index.json\"\n}\n"
          },
          {
            "path": "/etc/systemd/system/caduceus.service",
            "mode": 420,
            "content": "[Unit]\nDescription=Caduceus HOMESERVER public appliance lever\nAfter=network-online.target\nWants=network-online.target\n\n[Service]\nType=simple\nExecStart=/usr/local/bin/caduceus serve\nEnvironment=CADUCEUS_BIND=0.0.0.0:3014\nEnvironment=PYTHONPATH=/usr/local/sbin\nRestart=on-failure\nRestartSec=2\n\n[Install]\nWantedBy=multi-user.target\n"
          },
          {
            "path": "/var/lib/caduceus/state.json",
            "mode": 420,
            "content": "{\n  \"schema\": \"caduceus.state.v1\",\n  \"services\": {\n    \"profile\": \"homeserver\"\n  },\n  \"caduceus\": {\n    \"household\": {\n      \"tls\": {\n        \"schema\": \"caduceus.household.tls.v1\",\n        \"root\": {},\n        \"leaves\": {},\n        \"bundles\": {},\n        \"constituents\": {},\n        \"trust\": {}\n      }\n    }\n  }\n}\n"
          }
        ],
        "caduceus_profile_source": {
          "source": "profiles/homeserver/index.yaml",
          "path": "/etc/caduceus/profile.yaml",
          "mode": 420,
          "insert_after_profile": "capability:\n  household_verifying_key:\n  default_ttl_seconds: 60",
          "insert_after_mode": "harmonia_profile: /etc/harmonia/profiles/homeserver/index.json",
          "append": "services:\n  ledger: /var/lib/harmonia/receipts/homeserver-ledger.jsonl\n  update:\n    timer: harmonia.timer\n    latest_receipt: /var/lib/harmonia/receipts/update-latest/run.json\n  coronatio:\n    latest_receipt: /var/lib/harmonia/receipts/homeserver-activate-latest/modules/coronatio/run.json\n  caduceus:\n    latest_receipt: /var/lib/harmonia/receipts/homeserver-activate-latest/modules/caduceus/run.json\nharmonia_routes:\n  update_now:\n    bin: /usr/local/bin/harmonia\n    args:\n    - homeserver-update\n    - /etc/harmonia/profiles/homeserver/index.json\n    - --apply\n    - --receipt-dir\n    - /var/lib/harmonia/receipts/update-latest\n  update_check:\n    bin: /usr/local/bin/harmonia\n    args:\n    - homeserver-update\n    - /etc/harmonia/profiles/homeserver/index.json\n    - --receipt-dir\n    - /var/lib/harmonia/receipts/update-latest\noperator_aliases:\n  update: caduceus update now\n  update-check: caduceus update check\n  update-status: caduceus update status\n  receipts: caduceus receipts latest\n  health: caduceus health\n"
        }
      }
    },
    {
      "step_id": "caduceus-staff-shelf-from-synced-source",
      "tool": "command",
      "permutation": "capture",
      "args": {
        "program": "/usr/bin/sh",
        "args": [
          "-ceu",
          "source_root=/opt/caduceus/source/data/staff-actuators; staff_shelf=/usr/local/sbin/caduceus_staff; [ -d \"$source_root/caduceus_staff\" ]; /usr/bin/rm -rf \"$staff_shelf\"; /usr/bin/install -d -m 0755 \"$staff_shelf\"; /bin/cp -a \"$source_root/caduceus_staff/.\" \"$staff_shelf/\"; /usr/bin/find /usr/local/sbin -maxdepth 1 -type f -name \"caduceus-*\" -delete; /usr/bin/find \"$source_root\" -maxdepth 1 -type f -name \"caduceus-*\" -exec /usr/bin/install -m 0755 {} /usr/local/sbin/ \\;"
        ]
      }
    },
    {
      "step_id": "caduceus-sudoers-policy-files-root",
      "tool": "files",
      "permutation": "managed-files",
      "args": {}
    }
  ],
  "files_root": "files_root"
}
