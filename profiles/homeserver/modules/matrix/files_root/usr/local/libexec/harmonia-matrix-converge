#!/bin/sh
set -eu

export DEBIAN_FRONTEND=noninteractive

matrix_repo="https://packages.matrix.org/debian/"
matrix_key_url="https://packages.matrix.org/debian/matrix-org-archive-keyring.gpg"
matrix_key_sha256="c2d12a3b2dc4dec8f1d3bf51df6d16878fcfa47a2423b6b06ded502b3014c98b"
matrix_key_fingerprint="AAF9AE843A7584B5A3E4CD2BCF45A512DE2DA058"
element_version="1.12.23"
element_url="https://github.com/element-hq/element-web/releases/download/v${element_version}/element-v${element_version}.tar.gz"
element_sha256="d4ba438d5c6222cbab9175c20ce32373b8d7c9b344489b6911de8bd6a630c894"

os_release=/etc/os-release
if [ ! -r "$os_release" ]; then
    echo "matrix-suite-os-release-missing" >&2
    exit 1
fi
# shellcheck disable=SC1090
. "$os_release"
suite="${VERSION_CODENAME:-}"
case "$suite" in
    bookworm|trixie) ;;
    *)
        echo "matrix-suite-unsupported:${suite:-missing}" >&2
        exit 1
        ;;
esac

verify_sha256() {
    path="$1"
    expected="$2"
    actual="$(sha256sum "$path" | awk '{print $1}')"
    if [ "$actual" != "$expected" ]; then
        echo "sha256-mismatch:$path:$actual" >&2
        return 1
    fi
}

install_matrix_apt_source() {
    install -d -o root -g root -m 0755 /usr/share/keyrings /etc/apt/sources.list.d
    key=/usr/share/keyrings/matrix-org-archive-keyring.gpg
    tmp="$(mktemp)"
    curl -fsSL "$matrix_key_url" -o "$tmp"
    verify_sha256 "$tmp" "$matrix_key_sha256"
    if command -v gpg >/dev/null 2>&1; then
        if ! gpg --show-keys --with-fingerprint --with-colons "$tmp" 2>/dev/null | grep -Fq "fpr:::::::::${matrix_key_fingerprint}:"; then
            echo "matrix-key-fingerprint-mismatch" >&2
            rm -f "$tmp"
            exit 1
        fi
    fi
    if [ ! -f "$key" ] || ! cmp -s "$tmp" "$key"; then
        install -o root -g root -m 0644 "$tmp" "$key"
    fi
    rm -f "$tmp"
    printf 'deb [signed-by=%s] %s %s main\n' "$key" "$matrix_repo" "$suite" >/etc/apt/sources.list.d/matrix-org.list
}

install_element_web_fallback() {
    release=/usr/share/element-web
    marker="$release/.artifact-sha256"
    if [ -f "$marker" ] && [ "$(cat "$marker")" = "$element_sha256" ] && [ -f "$release/index.html" ]; then
        return 0
    fi
    work="$(mktemp -d)"
    archive="$work/element-web.tar.gz"
    staging="$work/staging"
    mkdir -p "$staging"
    curl -fsSL "$element_url" -o "$archive"
    verify_sha256 "$archive" "$element_sha256"
    tar -xzf "$archive" -C "$staging" --strip-components=1
    test -f "$staging/index.html"
    printf '%s\n' "$element_sha256" >"$staging/.artifact-sha256"
    install -d -o root -g root -m 0755 /usr/share
    rm -rf "${release}.new" "${release}.old"
    mv "$staging" "${release}.new"
    if [ -d "$release" ]; then
        mv "$release" "${release}.old"
    fi
    mv "${release}.new" "$release"
    rm -rf "${release}.old" "$work"
}

# Package bytes come from the body's suite-specific Matrix.org apt repository,
# verified by pinned public keyring. Element Web is not suite-published for
# bookworm/trixie apt; converge the pinned release tarball into /usr/share.
install_matrix_apt_source
apt-get update
apt-get install -y \
    -o Dpkg::Options::=--force-confdef \
    -o Dpkg::Options::=--force-confold \
    matrix-synapse-py3 nginx postgresql-client logrotate openssl unbound ca-certificates curl tar
install_element_web_fallback

getent group matrix-synapse >/dev/null 2>&1 || groupadd --system matrix-synapse
id -u matrix-synapse >/dev/null 2>&1 || useradd --system --gid matrix-synapse --home-dir /var/lib/matrix-synapse --shell /usr/sbin/nologin matrix-synapse

install -d -o root -g matrix-synapse -m 0750 /etc/matrix-synapse /etc/matrix-synapse/conf.d
install -d -o matrix-synapse -g matrix-synapse -m 0750 /var/lib/matrix-synapse /var/lib/matrix-synapse/media
install -d -o matrix-synapse -g adm -m 0750 /var/log/matrix-synapse
install -d -o root -g root -m 0755 /usr/share/harmonia/matrix

# Birth-owned values are generated once. Harmonia owns only presence, owner, and mode;
# it never renders or replaces this file.
secrets=/etc/matrix-synapse/conf.d/90-birth-secrets.yaml
if [ ! -e "$secrets" ]; then
    umask 077
    macaroon_secret_key="$(openssl rand -hex 32)"
    form_secret="$(openssl rand -hex 32)"
    registration_shared_secret="$(openssl rand -hex 32)"
    tmp="${secrets}.new.$$"
    {
        printf 'macaroon_secret_key: "%s"\n' "$macaroon_secret_key"
        printf 'form_secret: "%s"\n' "$form_secret"
        printf 'registration_shared_secret: "%s"\n' "$registration_shared_secret"
    } >"$tmp"
    chown root:matrix-synapse "$tmp"
    chmod 0640 "$tmp"
    mv "$tmp" "$secrets"
fi
chown root:matrix-synapse "$secrets"
chmod 0640 "$secrets"

chown root:matrix-synapse /etc/matrix-synapse/homeserver.yaml /etc/matrix-synapse/log.yaml
chmod 0640 /etc/matrix-synapse/homeserver.yaml /etc/matrix-synapse/log.yaml

ensure_postgres_peer_admission() {
    desired='local   synapse         matrix-synapse                          peer'
    changed=0
    found=0
    for hba in /etc/postgresql/*/main/pg_hba.conf; do
        [ -f "$hba" ] || continue
        found=1
        if grep -Fqx "$desired" "$hba"; then
            continue
        fi
        tmp="${hba}.harmonia-matrix-new.$$"
        awk -v desired="$desired" '
            $1 == "local" && $2 == "all" && $3 == "all" && $4 == "scram-sha-256" && !inserted {
                print desired
                inserted = 1
            }
            { print }
            END {
                if (!inserted) {
                    print desired
                }
            }
        ' "$hba" >"$tmp"
        chown --reference="$hba" "$tmp"
        chmod --reference="$hba" "$tmp"
        mv "$tmp" "$hba"
        changed=1
    done
    if [ "$found" -eq 0 ]; then
        echo "matrix-postgresql-pg-hba-missing" >&2
        return 1
    fi
    if [ "$changed" -eq 1 ]; then
        runuser -u postgres -- psql --set=ON_ERROR_STOP=1 --command='SELECT pg_reload_conf();' postgres >/dev/null
    fi
}

ensure_unbound_conf_d_include() {
    conf=/etc/unbound/unbound.conf
    include='include-toplevel: "/etc/unbound/unbound.conf.d/*.conf"'
    [ -f "$conf" ] || return 0
    if grep -Fqx "$include" "$conf"; then
        return 0
    fi
    printf '\n%s\n' "$include" >>"$conf"
}

# psql's \gexec declarations create missing objects and converge role attributes;
# peer authentication means no database password is required or stored.
runuser -u postgres -- psql --set=ON_ERROR_STOP=1 --file=/usr/share/harmonia/matrix/postgres.sql postgres
ensure_postgres_peer_admission
ensure_unbound_conf_d_include

ln -sfn /etc/nginx/sites-available/homeserver-matrix /etc/nginx/sites-enabled/homeserver-matrix
ln -sfn /etc/nginx/sites-available/homeserver-element /etc/nginx/sites-enabled/homeserver-element

test -f /usr/share/element-web/index.html

python3 - <<'PY'
import json
from pathlib import Path

path = Path('/etc/homeserver.json')
if path.exists():
    data = json.loads(path.read_text(encoding='utf-8'))
else:
    data = {'tabs': {}, 'global': {}, 'capabilities': {}, 'settings': {}}
if not isinstance(data, dict):
    raise SystemExit('homeserver-json-root-not-object')
for key in ('tabs', 'global', 'capabilities', 'settings'):
    data.setdefault(key, {})
    if not isinstance(data[key], dict):
        raise SystemExit(f'homeserver-json-{key}-not-object')
portals_tab = data['tabs'].setdefault('portals', {})
if not isinstance(portals_tab, dict):
    raise SystemExit('homeserver-json-portals-tab-not-object')
visibility = portals_tab.setdefault('visibility', {})
if not isinstance(visibility, dict):
    raise SystemExit('homeserver-json-portals-visibility-not-object')
visibility.setdefault('tab', True)
elements = visibility.setdefault('elements', {})
if not isinstance(elements, dict):
    raise SystemExit('homeserver-json-portals-elements-not-object')
elements['element'] = True
pdata = portals_tab.setdefault('data', {})
if not isinstance(pdata, dict):
    raise SystemExit('homeserver-json-portals-data-not-object')
items = pdata.setdefault('portals', [])
if not isinstance(items, list):
    raise SystemExit('homeserver-json-portals-list-not-array')
entry = {
    'name': 'element',
    'description': 'Private chat for your homeserver.',
    'services': ['matrix-synapse.service', 'nginx.service'],
    'owningUnits': ['matrix-synapse.service', 'nginx.service'],
    'type': 'systemd',
    'port': 443,
    'localURL': 'https://chat.home.arpa',
    'remoteURL': '',
    'status': 'unknown',
}
for index, item in enumerate(items):
    if isinstance(item, dict) and item.get('name') == 'element':
        items[index] = {**item, **entry}
        break
else:
    items.append(entry)
tmp = path.with_suffix(path.suffix + '.harmonia-matrix-new')
tmp.write_text(json.dumps(data, indent=2, sort_keys=False) + '\n', encoding='utf-8')
tmp.replace(path)
PY

nginx -t
unbound-checkconf
logrotate --debug /etc/logrotate.d/matrix-synapse >/dev/null

if systemctl is-active --quiet nginx.service; then
    systemctl reload nginx.service
fi
if systemctl is-active --quiet unbound.service; then
    systemctl reload unbound.service
fi
